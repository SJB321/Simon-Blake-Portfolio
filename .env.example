# Copy this file to `.env` (which is gitignored) and fill in your real values.
# In Vercel, set the same two variables under Project Settings → Environment Variables.

# Supabase pooled connection (port 6543) — used at request time by serverless functions
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct connection (port 5432) — used by `prisma db push` and `prisma db seed`
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres"

# Supabase Storage — used by /api/images to upload/list/delete files
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_KEY="sb_secret_..."

# OpenAI — used by /api/ai/revise and /api/ai/advise for content suggestions on the edit page.
# Create a project-scoped key at https://platform.openai.com/api-keys with a low monthly
# hard limit. Server-side only — never exposed to the browser bundle.
OPENAI_API_KEY="sk-proj-..."
