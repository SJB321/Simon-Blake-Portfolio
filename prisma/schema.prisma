// Prisma schema for the resume content database.
//
// Two flavors of model:
//   1. Singleton sections (Profile, About, Education, Settings) — there's only
//      ever one row. They use id = 1 as a convention so updates use upsert.
//   2. Repeating sections (SkillGroup, Project, Experience) — multiple rows,
//      ordered by an explicit `order` int so the admin can rearrange.
//
// Inner arrays-of-strings (interests, honors, coursework, tech, impact, items,
// points) live as JSON columns instead of their own tables — they're always
// fetched and saved with their parent, and over-normalizing buys nothing here.
//
// Migrations: this project uses `prisma db push` rather than full migrations,
// since there's a single deployer (you). If multiple devs ever touch the DB,
// switch to `prisma migrate dev` / `prisma migrate deploy`.

generator client {
  provider      = "prisma-client-js"
  // `native` builds for your dev machine; the second entry builds the Linux
  // binary Vercel needs at runtime. Without it the deployed function can't
  // find a Prisma engine that matches its OS and crashes with "Query engine
  // library for current platform could not be located".
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // Pooled — for runtime queries
  directUrl = env("DIRECT_URL")    // Direct — for migrations / db push
}

/// Hero & contact details. Singleton.
model Profile {
  id           Int      @id @default(1)
  name         String
  role         String
  location     String
  email        String
  phone        String?
  github       String?
  linkedin     String?
  availability String?
  tagline      String?
  intro        String   @db.Text
  imageUrl     String?  // Profile photo (Supabase Storage URL). Falls back to /Profile.jpeg if unset.
  updatedAt    DateTime @updatedAt
}

/// "About me" prose. Singleton.
/// - paragraphs: ordered array of paragraph strings
/// - interests:  array of bullet strings
model About {
  id         Int      @id @default(1)
  paragraphs Json
  interests  Json
  updatedAt  DateTime @updatedAt
}

/// Education record. Singleton (one school for now; convert to many-rows if needed later).
model Education {
  id         Int      @id @default(1)
  school     String
  college    String?
  degree     String
  location   String
  period     String
  gpa        String?
  honors     Json     // string[]
  coursework Json     // string[]
  imageUrl   String?  // Optional school/department image
  updatedAt  DateTime @updatedAt
}

/// One row per skill group ("Languages", "Tools", etc.). Many.
model SkillGroup {
  id        Int      @id @default(autoincrement())
  title     String
  items     Json     // string[]
  order     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([order])
}

/// One row per project. Many.
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  role        String
  year        String
  description String   @db.Text
  impact      Json     // string[]
  tech        Json     // string[]
  githubUrl   String?
  demoUrl     String?
  imageUrl    String?  // Optional cover image (Supabase Storage URL)
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@index([order])
}

/// One row per past role / job. Many.
model Experience {
  id        Int      @id @default(autoincrement())
  role      String
  company   String
  location  String
  period    String
  points    Json     // string[]
  imageUrl  String?  // Optional small image / company logo
  order     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([order])
}

/// App-level settings. Singleton.
/// passwordHash = null  → admin is unprotected (no password configured)
/// passwordHash = "..." → bcrypt hash; admin endpoints require matching password
/// activeThemeId        → which Theme the public site renders. null = built-in defaults.
model Settings {
  id            Int      @id @default(1)
  passwordHash  String?
  activeThemeId Int?
  updatedAt     DateTime @updatedAt
}

/// Visual theme of the public site (and PDF, where supported).
/// Multiple may exist; one is "active" via Settings.activeThemeId.
model Theme {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  description     String?

  // Typography — `font` holds a CSS-ready font-family value (e.g. "Lora",
  // including any quotes). `fontUrl` is set when this is a custom Google
  // Font we have to load dynamically; null when it's a curated preset
  // that's already preloaded.
  headingFont     String   @default("Source Serif 4")
  headingFontUrl  String?
  bodyFont        String   @default("Source Sans 3")
  bodyFontUrl     String?

  // Accent color (hex). Drives buttons, links, eyebrows, dots, divider dots,
  // and PDF section headings.
  accentColor       String   @default("#1e3a5f")

  // Page background — the body color behind everything.
  backgroundColor   String   @default("#fafaf9")

  // "Box" colors — the card surfaces (project cards, education card, etc.)
  // and the outline color around them.
  cardBackgroundColor String @default("#ffffff")
  cardBorderColor     String @default("#e7e5e4")

  // Spacing preset: 'compact' | 'comfortable' | 'spacious'.
  // Maps to a CSS variable that scales section padding on the public site.
  spacing         String   @default("comfortable")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
